# Backend environment variables

# Mongo
# Local:
# MONGO_URI=mongodb://127.0.0.1:27017/team_task_manager
#
# Vercel production should use a hosted MongoDB Atlas URI:
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/team_task_manager?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_me_to_a_long_random_secret

# Server
PORT=5000

# CORS
# Local example:
# CORS_ORIGIN=http://localhost:3000
#
# Production example:
CORS_ORIGIN=https://your-vercel-app.vercel.app
